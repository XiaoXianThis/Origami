---
const modes = [
  { name: '最小化', description: '兼容性最好，切换时会有最小化 / 恢复痕迹。', tag: '稳定' },
  { name: '透明隐藏', description: '更无痕，不进入 Dock 最小化区。', tag: '推荐' },
  { name: 'Overlay 切换', description: '用窗口快照遮住切换过程，体感更接近瞬时切换。', tag: '流畅' },
  { name: '底层跟随', description: '非当前窗口缩小并叠在当前窗口底层。', tag: '视觉' },
  { name: '移动到屏外', description: '非当前窗口临时移到屏幕外。', tag: '经典' },
  { name: '移动到其他桌面', description: '临时移到另一个 Space，需至少两个普通桌面。', tag: 'Space' },
  { name: '缩到极小', description: '非当前窗口缩到极小尺寸，切换时再恢复。', tag: '轻量' },
];
---

<section id="hide-modes" class="border-t border-white/5 bg-[#12141c] px-6 py-24">
  <div class="mx-auto max-w-6xl">
    <div class="grid gap-12 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start">
      <div>
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-amber-300/80">Hide Modes</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-white md:text-4xl">七种隐藏方式，按场景切换</h2>
        <p class="mt-4 text-lg leading-8 text-stone-400">
          不同 App、不同 macOS 版本对窗口控制的兼容性各异。Origami 提供多种策略，你可以在设置里随时切换，找到最适合自己的无痕方案。
        </p>

        <div class="mt-8 rounded-2xl border border-amber-400/20 bg-amber-400/5 p-5">
          <p class="text-sm leading-7 text-amber-100/90">
            <span class="font-semibold text-amber-200">提示：</span>
            首次运行需要在「系统设置 → 隐私与安全性 → 辅助功能」中授权 Origami，以便控制窗口位置与状态。
          </p>
        </div>
      </div>

      <div class="space-y-3">
        {modes.map((mode, index) => (
          <div class="flex gap-4 rounded-2xl border border-white/5 bg-[#0f1117] p-5 transition hover:border-white/10">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-white/5 text-sm font-semibold text-stone-300">
              {String(index + 1).padStart(2, '0')}
            </div>
            <div class="min-w-0">
              <div class="flex flex-wrap items-center gap-2">
                <h3 class="font-medium text-white">{mode.name}</h3>
                <span class="rounded-full bg-white/5 px-2 py-0.5 text-xs text-stone-400">{mode.tag}</span>
              </div>
              <p class="mt-2 text-sm leading-6 text-stone-500">{mode.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
