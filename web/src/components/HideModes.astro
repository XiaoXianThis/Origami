---
const modes = [
  { name: '最小化', description: '兼容性最好，切换时会有最小化 / 恢复痕迹。', tag: '稳定' },
  { name: '透明隐藏', description: '更无痕，不进入 Dock 最小化区。', tag: '推荐' },
  { name: 'Overlay 切换', description: '用窗口快照遮住切换过程，体感更接近瞬时切换。', tag: '流畅' },
  { name: '底层跟随', description: '非当前窗口缩小并叠在当前窗口底层。', tag: '视觉' },
  { name: '移动到屏外', description: '非当前窗口临时移到屏幕外。', tag: '经典' },
  { name: '移动到其他桌面', description: '临时移到另一个 Space，需至少两个普通桌面。', tag: 'Space' },
  { name: '缩到极小', description: '非当前窗口缩到极小尺寸，切换时再恢复。', tag: '轻量' },
];
---

<section id="hide-modes" class="border-t border-sky-200/50 bg-sky-100/30 px-4 py-24 backdrop-blur-sm sm:px-6">
  <div class="mx-auto max-w-6xl min-w-0">
    <div class="grid gap-12 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start">
      <div>
        <p class="section-label">Hide Modes</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-slate-900 md:text-4xl">七种隐藏方式，按场景切换</h2>
        <p class="mt-4 text-lg leading-8 text-slate-600">
          不同 App、不同 macOS 版本对窗口控制的兼容性各异。Origami 提供多种策略，你可以在设置里随时切换，找到最适合自己的无痕方案。
        </p>

        <div class="mt-8 rounded-2xl border border-cyan-300/40 bg-cyan-50/70 p-5 backdrop-blur-sm">
          <p class="text-sm leading-7 text-cyan-900/90">
            <span class="font-semibold text-cyan-800">提示：</span>
            首次运行需要在「系统设置 → 隐私与安全性 → 辅助功能」中授权 Origami，以便控制窗口位置与状态。
          </p>
        </div>
      </div>

      <div class="space-y-3">
        {modes.map((mode, index) => (
          <div class="flex gap-4 glass-card p-5 transition hover:border-cyan-300/40 hover:bg-white/70">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-cyan-100/70 text-sm font-semibold text-cyan-800">
              {String(index + 1).padStart(2, '0')}
            </div>
            <div class="min-w-0">
              <div class="flex flex-wrap items-center gap-2">
                <h3 class="font-medium text-slate-900">{mode.name}</h3>
                <span class="rounded-full bg-sky-100/80 px-2 py-0.5 text-xs text-cyan-700">{mode.tag}</span>
              </div>
              <p class="mt-2 text-sm leading-6 text-slate-600">{mode.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
