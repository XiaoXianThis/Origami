---
const features = [
  {
    title: '窗口分组与标签栏',
    description: '将多个窗口合并为一组，在窗口顶部显示可点击的标签栏，切换就像浏览器标签一样自然。',
    icon: 'layers',
  },
  {
    title: '无痕切换',
    description: '七种隐藏策略可选，切换组内窗口时尽量不留最小化痕迹，保持桌面整洁。',
    icon: 'sparkles',
  },
  {
    title: '拖拽分组',
    description: '拖动标签合并窗口组；拖出窗口后可自动移出当前组，分组逻辑由你掌控。',
    icon: 'move',
  },
  {
    title: '标签位置自定义',
    description: '水平 / 垂直锚点、内外位置、偏移与最大宽度均可调节，适配不同窗口布局。',
    icon: 'sliders',
  },
  {
    title: '屏外窗口恢复',
    description: '根据窗口真实位置检测屏外窗口，不依赖软件内部记录，一键移回屏幕内。',
    icon: 'monitor',
  },
  {
    title: '主题同步',
    description: '浅色、深色或跟随系统，标签栏与设置窗口同步切换，融入 macOS 外观。',
    icon: 'palette',
  },
];

const icons: Record<string, string> = {
  layers: 'M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 010 3.75H5.625a1.875 1.875 0 010-3.75z',
  sparkles: 'M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z',
  move: 'M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15',
  sliders: 'M10.5 6h9.75M10.5 6a1.875 1.875 0 11-3.75 0 1.875 1.875 0 013.75 0zm-8.25 6h9.75M3.75 12a1.875 1.875 0 113.75 0 1.875 1.875 0 01-3.75 0zm8.25 6h9.75m-9.75 0a1.875 1.875 0 113.75 0 1.875 1.875 0 01-3.75 0z',
  monitor: 'M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25',
  palette: 'M4.098 19.902a3.75 3.75 0 005.304 0l6.401-6.402M6.75 21A3.75 3.75 0 013 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 003.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008z',
};
---

<section id="features" class="border-t border-white/5 px-6 py-24">
  <div class="mx-auto max-w-6xl">
    <div class="max-w-2xl">
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-amber-300/80">Features</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-white md:text-4xl">为 macOS 多窗口场景而生</h2>
      <p class="mt-4 text-lg leading-8 text-stone-400">
        不是简单的窗口管理器，而是把「标签页思维」带到原生应用窗口上——分组、切换、隐藏，一气呵成。
      </p>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {features.map((feature) => (
        <article class="group rounded-2xl border border-white/5 bg-white/[0.02] p-6 transition hover:border-amber-400/20 hover:bg-amber-400/[0.03]">
          <div class="mb-5 inline-flex h-11 w-11 items-center justify-center rounded-xl bg-amber-400/10 text-amber-300 ring-1 ring-amber-400/20">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={icons[feature.icon]} />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white">{feature.title}</h3>
          <p class="mt-3 text-sm leading-7 text-stone-400">{feature.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
