---
import PreviewVideo from './PreviewVideo.astro';
---

<section class="relative overflow-hidden px-6 pb-24 pt-16 md:pb-32 md:pt-24">
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute -top-32 left-1/2 h-[28rem] w-[28rem] -translate-x-1/2 rounded-full bg-cyan-400/20 blur-3xl"></div>
    <div class="absolute right-0 top-1/3 h-72 w-72 rounded-full bg-blue-500/15 blur-3xl"></div>
    <div class="absolute bottom-0 left-0 h-64 w-64 rounded-full bg-sky-300/20 blur-3xl"></div>
  </div>

  <div class="relative mx-auto max-w-7xl">
    <div class="max-w-2xl">
      <p class="mb-4 inline-flex items-center gap-2 rounded-full border border-cyan-300/40 bg-cyan-50/70 px-3 py-1 text-xs font-medium text-cyan-800 backdrop-blur-sm">
        <span class="h-1.5 w-1.5 rounded-full bg-cyan-500"></span>
        macOS 13+ · 菜单栏工具 · 开源
      </p>

      <h1 class="max-w-xl text-4xl font-semibold leading-tight tracking-tight text-slate-900 md:text-5xl md:leading-[1.1]">
        像折纸一样，
        <span class="text-gradient-brand">
          把窗口叠成一组
        </span>
      </h1>

      <p class="mt-6 max-w-lg text-lg leading-8 text-slate-600">
        Origami 是一款 macOS 菜单栏工具。它把多个应用窗口合并成组，在窗口上方叠加标签栏，让你像切换浏览器标签一样快速、无痕地切换窗口。
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-4">
        <a href="#download" class="btn-primary">
          下载 Origami
        </a>
        <a href="#demo" class="btn-secondary demo-hide-narrow-portrait">
          在线演示
        </a>
        <a
          href="https://github.com/XiaoXianThis/Origami"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary"
        >
          查看源码
        </a>
      </div>
    </div>

    <div class="mt-12 md:mt-14">
      <PreviewVideo />
    </div>

    <dl class="mt-12 grid grid-cols-3 gap-4 border-t border-sky-200/60 pt-8 md:mt-14 md:max-w-2xl">
      <div>
        <dt class="text-2xl font-semibold text-slate-900">7</dt>
        <dd class="mt-1 text-sm text-slate-500">种隐藏策略</dd>
      </div>
      <div>
        <dt class="text-2xl font-semibold text-slate-900">0</dt>
        <dd class="mt-1 text-sm text-slate-500">Dock 最小化痕迹</dd>
      </div>
      <div>
        <dt class="text-2xl font-semibold text-slate-900">∞</dt>
        <dd class="mt-1 text-sm text-slate-500">自由分组</dd>
      </div>
    </dl>
  </div>
</section>
