---
import PreviewVideo from './PreviewVideo.astro';
import OrigamiPronunciation from './OrigamiPronunciation.astro';
import type { Translations } from '../i18n';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section class="relative overflow-hidden px-4 pb-24 pt-16 sm:px-6 md:pb-32 md:pt-24">
  <div class="relative mx-auto max-w-7xl">
    <div class="mx-auto max-w-2xl text-center">
      <img
        src="/icon.png"
        alt="Origami"
        width="96"
        height="96"
        class="mx-auto mb-6 h-20 w-20 rounded-[1.35rem] shadow-xl shadow-cyan-500/20 sm:h-24 sm:w-24"
      />

      <p class="mb-4 inline-flex items-center gap-2 rounded-full border border-cyan-300/40 bg-cyan-50/70 px-3 py-1 text-xs font-medium text-cyan-800 backdrop-blur-sm dark:border-cyan-500/30 dark:bg-cyan-950/40 dark:text-cyan-300">
        <span class="h-1.5 w-1.5 rounded-full bg-cyan-500"></span>
        {t.hero.badge}
      </p>

      <div class="mb-3 flex justify-center">
        <OrigamiPronunciation class="text-base md:text-lg" ariaLabel={t.pronunciation.aria} />
      </div>

      <h1 class="mx-auto text-3xl font-semibold leading-tight tracking-tight text-slate-900 dark:text-slate-100 sm:text-4xl md:text-5xl md:leading-[1.1] lg:whitespace-nowrap">
        {t.hero.titlePrefix}<span class="text-gradient-brand">{t.hero.titleHighlight}</span>
      </h1>

      <p class="mx-auto mt-6 max-w-lg text-lg leading-8 text-slate-600 dark:text-slate-400">
        {t.hero.description}
      </p>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a href="#download" class="btn-primary">
          {t.hero.download}
        </a>
        <a href="#demo" class="btn-secondary demo-hide-narrow-portrait">
          {t.hero.demo}
        </a>
        <a
          href="https://github.com/XiaoXianThis/Origami"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary"
        >
          {t.hero.source}
        </a>
      </div>
    </div>

    <div class="mt-12 md:mt-14">
      <PreviewVideo />
    </div>
  </div>
</section>
