---
/** 全页滚动视差背景：点阵、网格、粒子与纹理，随滚动产生层次感 */
---

<div id="scroll-bg" class="scroll-bg" aria-hidden="true">
  <div class="scroll-bg__layer scroll-bg__dots" data-parallax="0.06"></div>
  <div class="scroll-bg__layer scroll-bg__grid" data-parallax="0.1"></div>

  <div class="scroll-bg__layer scroll-bg__particles" data-parallax="0.14">
    <span class="scroll-bg__particle scroll-bg__particle--1" data-parallax="0.22"></span>
    <span class="scroll-bg__particle scroll-bg__particle--2" data-parallax="0.18"></span>
    <span class="scroll-bg__particle scroll-bg__particle--3" data-parallax="0.28"></span>
    <span class="scroll-bg__particle scroll-bg__particle--4" data-parallax="0.16"></span>
    <span class="scroll-bg__particle scroll-bg__particle--5" data-parallax="0.24"></span>
    <span class="scroll-bg__particle scroll-bg__particle--6" data-parallax="0.12"></span>
    <span class="scroll-bg__particle scroll-bg__particle--7" data-parallax="0.2"></span>
    <span class="scroll-bg__particle scroll-bg__particle--8" data-parallax="0.15"></span>
  </div>

  <div class="scroll-bg__layer scroll-bg__rings" data-parallax="0.08">
    <span class="scroll-bg__ring scroll-bg__ring--1" data-parallax="0.12"></span>
    <span class="scroll-bg__ring scroll-bg__ring--2" data-parallax="0.18"></span>
  </div>

  <div class="scroll-bg__layer scroll-bg__grain" data-parallax="0.04"></div>
  <div class="scroll-bg__layer scroll-bg__cross" data-parallax="0.07"></div>
</div>

<style>
  .scroll-bg {
    pointer-events: none;
    position: fixed;
    inset: 0;
    z-index: 1;
    overflow: hidden;
  }

  .scroll-bg__layer {
    position: absolute;
    will-change: transform;
  }

  /* 大范围点阵 */
  .scroll-bg__dots {
    inset: -20%;
    opacity: 0.55;
    background-image: radial-gradient(circle, rgba(0, 153, 204, 0.22) 1px, transparent 1px);
    background-size: 28px 28px;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, black 20%, transparent 75%);
  }

  /* 细网格线 */
  .scroll-bg__grid {
    inset: -15%;
    opacity: 0.35;
    background-image:
      linear-gradient(rgba(0, 153, 204, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 153, 204, 0.06) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: linear-gradient(180deg, transparent 0%, black 15%, black 85%, transparent 100%);
  }

  .scroll-bg__particles {
    inset: 0;
  }

  .scroll-bg__particle {
    position: absolute;
    display: block;
    border-radius: 9999px;
    will-change: transform;
  }

  .scroll-bg__particle--1 {
    top: 12%;
    left: 8%;
    width: 6px;
    height: 6px;
    background: rgba(0, 212, 255, 0.45);
    box-shadow: 0 0 12px rgba(0, 212, 255, 0.35);
  }

  .scroll-bg__particle--2 {
    top: 28%;
    right: 12%;
    width: 4px;
    height: 4px;
    background: rgba(0, 153, 204, 0.5);
  }

  .scroll-bg__particle--3 {
    top: 45%;
    left: 18%;
    width: 8px;
    height: 8px;
    background: rgba(0, 183, 235, 0.25);
    border: 1px solid rgba(0, 153, 204, 0.3);
  }

  .scroll-bg__particle--4 {
    top: 62%;
    right: 22%;
    width: 5px;
    height: 5px;
    background: rgba(0, 86, 179, 0.35);
  }

  .scroll-bg__particle--5 {
    top: 78%;
    left: 28%;
    width: 3px;
    height: 3px;
    background: rgba(0, 212, 255, 0.55);
  }

  .scroll-bg__particle--6 {
    top: 18%;
    left: 42%;
    width: 4px;
    height: 4px;
    background: rgba(0, 153, 204, 0.4);
  }

  .scroll-bg__particle--7 {
    top: 55%;
    right: 8%;
    width: 7px;
    height: 7px;
    background: rgba(0, 212, 255, 0.2);
    border: 1px solid rgba(0, 183, 235, 0.25);
  }

  .scroll-bg__particle--8 {
    top: 88%;
    right: 35%;
    width: 4px;
    height: 4px;
    background: rgba(0, 153, 204, 0.45);
  }

  /* 装饰圆环 */
  .scroll-bg__rings {
    inset: 0;
  }

  .scroll-bg__ring {
    position: absolute;
    display: block;
    border-radius: 9999px;
    border: 1px solid rgba(0, 153, 204, 0.12);
    will-change: transform;
  }

  .scroll-bg__ring--1 {
    top: 8%;
    right: -4%;
    width: 22rem;
    height: 22rem;
  }

  .scroll-bg__ring--2 {
    bottom: 10%;
    left: -6%;
    width: 18rem;
    height: 18rem;
    border-color: rgba(0, 212, 255, 0.1);
  }

  /* 噪点纹理 */
  .scroll-bg__grain {
    inset: 0;
    opacity: 0.35;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 180px 180px;
    mix-blend-mode: soft-light;
  }

  /* 斜向细线纹理 */
  .scroll-bg__cross {
    inset: -10%;
    opacity: 0.25;
    background-image: repeating-linear-gradient(
      -35deg,
      transparent,
      transparent 48px,
      rgba(0, 153, 204, 0.04) 48px,
      rgba(0, 153, 204, 0.04) 49px
    );
    mask-image: radial-gradient(ellipse 90% 80% at 50% 50%, black 30%, transparent 80%);
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-bg__layer,
    .scroll-bg__particle,
    .scroll-bg__ring {
      will-change: auto;
    }
  }

  @media (max-width: 640px) {
    .scroll-bg__dots {
      background-size: 22px 22px;
      opacity: 0.4;
    }

    .scroll-bg__grid {
      opacity: 0.25;
    }

    .scroll-bg__ring--1 {
      width: 14rem;
      height: 14rem;
    }

    .scroll-bg__ring--2 {
      width: 12rem;
      height: 12rem;
    }
  }
</style>

<script>
  const root = document.getElementById('scroll-bg');
  if (!root) {
    /* 无背景容器时跳过 */
  } else {
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const layers = root.querySelectorAll<HTMLElement>('[data-parallax]');

    let ticking = false;

    function applyParallax() {
      const scrollY = window.scrollY;
      for (const el of layers) {
        const speed = Number(el.dataset.parallax ?? 0);
        el.style.transform = `translate3d(0, ${scrollY * speed}px, 0)`;
      }
      ticking = false;
    }

    function onScroll() {
      if (reducedMotion || ticking) return;
      ticking = true;
      requestAnimationFrame(applyParallax);
    }

    if (!reducedMotion) {
      applyParallax();
      window.addEventListener('scroll', onScroll, { passive: true });
    }
  }
</script>
