---
import MacOSDemo from './demo/MacOSDemo.astro';

const steps = [
  {
    num: '01',
    title: '拖动标签',
    desc: '按住窗口外的标签，拖向另一个窗口',
    icon: 'M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z M6 6h.008v.008H6V6z',
  },
  {
    num: '02',
    title: '拖入合并',
    desc: '释放在目标窗口上，合并为同一组',
    icon: 'M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 010 3.75H5.625a1.875 1.875 0 010-3.75z',
  },
  {
    num: '03',
    title: '点击切换',
    desc: '在标签栏点击，即时切换组内窗口',
    icon: 'M15.042 21.672L13.684 16.6m0 0l-2.51 2.225.569-9.47 5.227 7.917-3.286-.672z',
  },
];
---

<section id="demo" class="demo-hide-narrow-portrait scroll-mt-16 overflow-visible px-2 py-16 sm:px-3 md:py-20 lg:px-4">
  <div class="demo-section-shell">
    <div class="demo-section-bg" aria-hidden="true">
      <div class="demo-bg-dots"></div>
      <div class="demo-bg-blob demo-bg-blob--left"></div>
      <div class="demo-bg-blob demo-bg-blob--right"></div>
    </div>

    <div class="demo-section-inner">
      <header class="demo-section-header">
        <h2 class="demo-copy-title">
          亲手试试
          <span class="text-gradient-brand">Origami</span>
        </h2>
        <p class="demo-copy-lead">
          把多个 macOS 窗口合并成组，在窗口外叠加标签栏——像切换浏览器标签一样，快速、无痕地切换。
        </p>
      </header>

      <div class="demo-section-layout">
        <div class="demo-section-frame">
          <MacOSDemo />
        </div>

        <aside class="demo-section-copy" id="demo-section-copy" aria-label="演示引导步骤">
          <div class="demo-guide-card">
            <ol class="demo-guide-steps" id="demo-guide-steps">
              {steps.map((step, index) => (
                <li class="demo-guide-step" class:list={{ 'is-active': index === 0 }} data-step={index}>
                  <div class="demo-guide-rail" aria-hidden="true">
                    <span class="demo-guide-num">{step.num}</span>
                    {index < steps.length - 1 && <span class="demo-guide-connector"></span>}
                  </div>
                  <div class="demo-guide-row">
                    <span class="demo-guide-icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d={step.icon} />
                      </svg>
                    </span>
                    <div class="demo-guide-body">
                      <p class="demo-guide-title">{step.title}</p>
                      <p class="demo-guide-desc">{step.desc}</p>
                    </div>
                  </div>
                </li>
              ))}
            </ol>
          </div>
        </aside>
      </div>

      <p class="demo-section-tagline">简洁 · 高效 · 无痕</p>
    </div>
  </div>
</section>

<style>
  .demo-section-shell {
    position: relative;
    width: 100%;
    max-width: 92rem;
    margin: 0 auto;
    overflow: visible;
  }

  .demo-section-bg {
    pointer-events: none;
    position: absolute;
    inset: -4rem -3rem;
    overflow: visible;
  }

  .demo-bg-dots {
    position: absolute;
    left: 0;
    top: 18%;
    width: 9rem;
    height: 9rem;
    opacity: 0.45;
    background-image: radial-gradient(circle, rgba(0, 153, 204, 0.35) 1px, transparent 1px);
    background-size: 14px 14px;
    mask-image: radial-gradient(circle at center, black 30%, transparent 72%);
  }

  .demo-bg-blob {
    position: absolute;
    border-radius: 9999px;
    filter: blur(48px);
  }

  .demo-bg-blob--left {
    left: 0;
    bottom: 4%;
    width: 18rem;
    height: 18rem;
    background: rgba(0, 212, 255, 0.14);
  }

  .demo-bg-blob--right {
    right: 0;
    top: 6%;
    width: 16rem;
    height: 16rem;
    background: rgba(0, 86, 179, 0.1);
  }

  .demo-section-inner {
    position: relative;
    z-index: 1;
    overflow: visible;
  }

  .demo-section-header {
    max-width: 42rem;
    margin: 0 auto 2rem;
    text-align: center;
  }

  .demo-section-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) clamp(22rem, 40%, 32rem);
    align-items: center;
    gap: clamp(0.5rem, 1.5vw, 1.25rem);
    width: 100%;
    margin: 0 auto;
    overflow: visible;
  }

  .demo-section-frame {
    position: relative;
    width: 100%;
    height: min(74vh, 720px);
    overflow: visible;
  }

  .demo-section-copy {
    position: relative;
    align-self: center;
    z-index: 1;
    width: 100%;
    padding: 0;
    background: none;
    border: none;
    box-shadow: none;
    overflow: visible;
    pointer-events: none;
  }

  .demo-section-copy > * {
    pointer-events: auto;
  }

  .demo-copy-title {
    font-size: clamp(1.625rem, 2.6vw, 2.25rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: #0f172a;
  }

  .demo-copy-lead {
    margin-top: 0.875rem;
    font-size: clamp(1rem, 1.25vw, 1.125rem);
    line-height: 1.65;
    color: #64748b;
  }

  .demo-guide-card {
    padding: clamp(1.125rem, 1.8vw, 1.5rem);
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.85);
    background: rgba(255, 255, 255, 0.82);
    box-shadow:
      0 1px 2px rgba(15, 50, 90, 0.04),
      0 12px 32px rgba(15, 50, 90, 0.08);
    backdrop-filter: blur(12px);
  }

  .demo-guide-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .demo-guide-step {
    display: grid;
    grid-template-columns: 2.25rem 1fr;
    gap: 0.875rem;
    align-items: start;
    padding: 0.65rem 0;
    transition: opacity 0.35s ease;
  }

  .demo-guide-step:not(.is-active) {
    opacity: 0.62;
  }

  .demo-guide-rail {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: 100%;
  }

  .demo-guide-num {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: #0099cc;
    background: rgba(0, 212, 255, 0.12);
    border: 1px solid rgba(0, 153, 204, 0.18);
    transition:
      background 0.35s ease,
      border-color 0.35s ease,
      color 0.35s ease,
      box-shadow 0.35s ease;
  }

  .demo-guide-step.is-active .demo-guide-num {
    color: #fff;
    background: linear-gradient(135deg, #00d4ff, #0099cc);
    border-color: transparent;
    box-shadow: 0 4px 12px rgba(0, 153, 204, 0.28);
  }

  .demo-guide-connector {
    flex: 1;
    width: 2px;
    min-height: 1.25rem;
    margin: 0.35rem 0;
    border-radius: 2px;
    background: linear-gradient(180deg, rgba(0, 153, 204, 0.35), rgba(0, 153, 204, 0.12));
  }

  .demo-guide-row {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    min-width: 0;
  }

  .demo-guide-icon {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.75rem;
    color: #0099cc;
    background: rgba(0, 212, 255, 0.1);
    border: 1px solid rgba(0, 153, 204, 0.12);
  }

  .demo-guide-icon svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .demo-guide-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: #0f172a;
    transition: color 0.35s ease;
  }

  .demo-guide-step.is-active .demo-guide-title {
    color: #007bb8;
  }

  .demo-guide-desc {
    margin-top: 0.25rem;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: #64748b;
  }

  .demo-section-tagline {
    margin-top: 2rem;
    text-align: center;
    font-size: 0.8125rem;
    letter-spacing: 0.28em;
    color: #94a3b8;
  }

  @media (max-width: 900px) {
    .demo-section-header {
      margin-bottom: 1.25rem;
    }

    .demo-section-layout {
      grid-template-columns: 1fr;
      gap: 0.75rem;
      width: 100%;
    }

    .demo-section-frame {
      height: min(52vh, 480px);
    }

    .demo-section-copy {
      margin-top: 0.5rem;
    }

    .demo-guide-card {
      padding: 1rem;
    }

    .demo-guide-desc {
      font-size: 0.875rem;
    }
  }
</style>
