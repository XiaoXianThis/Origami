---
import MacOSDemo from './demo/MacOSDemo.astro';
import type { Translations } from '../i18n';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const steps = t.demo.steps;
---

<section id="demo" class="demo-hide-narrow-portrait scroll-mt-16 overflow-x-clip px-2 py-16 sm:px-3 md:py-20 lg:px-4">
  <div class="demo-section-shell">
    <div class="demo-section-bg" aria-hidden="true">
      <div class="demo-bg-dots"></div>
      <div class="demo-bg-blob demo-bg-blob--left"></div>
      <div class="demo-bg-blob demo-bg-blob--right"></div>
    </div>

    <div class="demo-section-inner">
      <header class="demo-section-header">
        <h2 class="page-section-title demo-copy-title">
          {t.demo.titlePrefix}
          <span class="text-gradient-brand">{t.demo.titleHighlight}</span>
        </h2>
        <p class="demo-copy-lead">
          {t.demo.lead}
        </p>
      </header>

      <div class="demo-section-layout">
        <div class="demo-section-frame">
          <MacOSDemo />
        </div>

        <aside class="demo-section-copy" id="demo-section-copy" aria-label={t.demo.stepsAria}>
          <div class="demo-guide-card">
            <ol class="demo-guide-steps" id="demo-guide-steps">
              {steps.map((step, index) => (
                <li class="demo-guide-step" class:list={{ 'is-active': index === 0 }} data-step={index}>
                  <div class="demo-guide-rail" aria-hidden="true">
                    <span class="demo-guide-num">{step.num}</span>
                    {index < steps.length - 1 && <span class="demo-guide-connector"></span>}
                  </div>
                  <div class="demo-guide-row">
                    <span class="demo-guide-icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d={step.icon} />
                      </svg>
                    </span>
                    <div class="demo-guide-body">
                      <p class="demo-guide-title">{step.title}</p>
                      <p class="demo-guide-desc">{step.desc}</p>
                    </div>
                  </div>
                </li>
              ))}
            </ol>
          </div>
        </aside>
      </div>

      <p class="demo-section-tagline">{t.demo.tagline}</p>
    </div>
  </div>
</section>

<style>
  .demo-section-shell {
    position: relative;
    width: 100%;
    max-width: 92rem;
    margin: 0 auto;
    overflow-x: clip;
  }

  .demo-section-bg {
    pointer-events: none;
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .demo-bg-dots {
    position: absolute;
    left: 0;
    top: 18%;
    width: 9rem;
    height: 9rem;
    opacity: 0.45;
    background-image: radial-gradient(circle, rgba(0, 153, 204, 0.35) 1px, transparent 1px);
    background-size: 14px 14px;
    mask-image: radial-gradient(circle at center, black 30%, transparent 72%);
  }

  .demo-bg-blob {
    position: absolute;
    border-radius: 9999px;
    filter: blur(48px);
  }

  .demo-bg-blob--left {
    left: 0;
    bottom: 4%;
    width: 18rem;
    height: 18rem;
    background: rgba(0, 212, 255, 0.14);
  }

  .demo-bg-blob--right {
    right: 0;
    top: 6%;
    width: 16rem;
    height: 16rem;
    background: rgba(0, 86, 179, 0.1);
  }

  .demo-section-inner {
    position: relative;
    z-index: 1;
    overflow: visible;
  }

  .demo-section-header {
    max-width: 42rem;
    margin: 0 auto 2rem;
    text-align: center;
  }

  .demo-section-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) clamp(22rem, 40%, 32rem);
    align-items: center;
    gap: clamp(0.5rem, 1.5vw, 1.25rem);
    width: 100%;
    margin: 0 auto;
    overflow: visible;
  }

  .demo-section-frame {
    position: relative;
    width: 100%;
    height: min(74vh, 720px);
    overflow: visible;
  }

  .demo-section-copy {
    position: relative;
    align-self: center;
    z-index: 1;
    width: 100%;
    padding: 0;
    background: none;
    border: none;
    box-shadow: none;
    overflow: visible;
    pointer-events: none;
  }

  .demo-section-copy > * {
    pointer-events: auto;
  }

  .demo-copy-lead {
    margin-top: 0.875rem;
    font-size: clamp(1rem, 1.25vw, 1.125rem);
    line-height: 1.65;
    color: var(--site-muted);
  }

  .demo-guide-card {
    padding: clamp(1.125rem, 1.8vw, 1.5rem);
    border-radius: 1rem;
    border: 1px solid var(--site-card-border);
    background: var(--site-card-bg);
    box-shadow:
      0 1px 2px rgba(15, 50, 90, 0.04),
      0 12px 32px rgba(15, 50, 90, 0.08);
    backdrop-filter: blur(12px);
  }

  :global(.dark) .demo-guide-card {
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.15),
      0 12px 32px rgba(0, 0, 0, 0.25);
  }

  .demo-guide-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .demo-guide-step {
    display: grid;
    grid-template-columns: 2.25rem 1fr;
    gap: 0.875rem;
    align-items: start;
    padding: 0.65rem 0;
    transition: opacity 0.35s ease;
  }

  .demo-guide-step:not(.is-active) {
    opacity: 0.62;
  }

  .demo-guide-rail {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: 100%;
  }

  .demo-guide-num {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: #0099cc;
    background: rgba(0, 212, 255, 0.12);
    border: 1px solid rgba(0, 153, 204, 0.18);
    transition:
      background 0.35s ease,
      border-color 0.35s ease,
      color 0.35s ease,
      box-shadow 0.35s ease;
  }

  .demo-guide-step.is-active .demo-guide-num {
    color: #fff;
    background: linear-gradient(135deg, #00d4ff, #0099cc);
    border-color: transparent;
    box-shadow: 0 4px 12px rgba(0, 153, 204, 0.28);
  }

  .demo-guide-connector {
    flex: 1;
    width: 2px;
    min-height: 1.25rem;
    margin: 0.35rem 0;
    border-radius: 2px;
    background: linear-gradient(180deg, rgba(0, 153, 204, 0.35), rgba(0, 153, 204, 0.12));
  }

  .demo-guide-row {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    min-width: 0;
  }

  .demo-guide-icon {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.75rem;
    color: #0099cc;
    background: rgba(0, 212, 255, 0.1);
    border: 1px solid rgba(0, 153, 204, 0.12);
  }

  .demo-guide-icon svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .demo-guide-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--site-text-strong);
    transition: color 0.35s ease;
  }

  .demo-guide-step.is-active .demo-guide-title {
    color: #007bb8;
  }

  .demo-guide-desc {
    margin-top: 0.25rem;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--site-muted);
  }

  .demo-section-tagline {
    margin-top: 2rem;
    text-align: center;
    font-size: 0.8125rem;
    letter-spacing: 0.28em;
    color: var(--site-muted);
  }

  @media (max-width: 900px) {
    .demo-section-header {
      margin-bottom: 1.25rem;
    }

    .demo-section-layout {
      grid-template-columns: 1fr;
      gap: 0.75rem;
      width: 100%;
    }

    .demo-section-frame {
      height: min(52vh, 480px);
    }

    .demo-section-copy {
      margin-top: 0.5rem;
    }

    .demo-guide-card {
      padding: 1rem;
    }

    .demo-guide-desc {
      font-size: 0.875rem;
    }
  }
</style>
