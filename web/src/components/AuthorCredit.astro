---
import type { Translations } from '../i18n';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const bilibiliUrl = 'https://space.bilibili.com/12724008';
---

<a
  href={bilibiliUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="author-credit fixed bottom-4 right-4 z-20 max-w-[calc(100%-2rem)] rounded-full border border-slate-200/40 bg-white/40 px-3 py-1.5 text-[11px] text-slate-400/80 backdrop-blur-sm transition hover:border-slate-300/50 hover:bg-white/60 hover:text-slate-500 dark:border-slate-600/40 dark:bg-slate-900/50 dark:text-slate-500 dark:hover:border-slate-500/50 dark:hover:bg-slate-900/70 dark:hover:text-slate-400"
  aria-label={t.author.aria}
>
  {t.author.label}
</a>
