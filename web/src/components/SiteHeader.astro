---
import LocaleToggle from './LocaleToggle.astro';
import ThemeToggle from './ThemeToggle.astro';
import type { Translations } from '../i18n';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<header id="site-header" class="site-header fixed inset-x-0 top-0 z-50">
  <div class="site-header-bar mx-auto flex max-w-6xl min-w-0 items-center justify-between gap-2 px-4 py-4 sm:gap-3 sm:px-6">
    <div class="flex min-w-0 flex-1 items-center gap-6 sm:gap-8">
      <a href="#" class="group flex min-w-0 shrink-0 items-center gap-2 sm:gap-3">
        <img
          src="/icon.png"
          alt=""
          width="36"
          height="36"
          class="h-9 w-9 rounded-xl shadow-lg shadow-cyan-500/25"
        />
        <span class="truncate text-lg font-semibold tracking-tight text-slate-900 transition-colors group-hover:text-cyan-700 dark:text-slate-100 dark:group-hover:text-cyan-400">
          Origami
        </span>
      </a>

      <nav class="hidden items-center gap-6 md:flex lg:gap-8">
        {t.header.nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              'text-sm text-slate-600 transition-colors hover:text-cyan-700 dark:text-slate-400 dark:hover:text-cyan-400',
              item.href === '#demo' && 'demo-hide-narrow-portrait',
            ]}
          >
            {item.label}
          </a>
        ))}
      </nav>
    </div>

    <div class="flex shrink-0 items-center gap-1.5 sm:gap-2">
      <ThemeToggle lightLabel={t.theme.light} darkLabel={t.theme.dark} toggleLabel={t.theme.toggle} />
      <LocaleToggle locale={t.locale} label={t.localeToggle.label} switchTo={t.localeToggle.switchTo} />
      <a
        href="https://github.com/XiaoXianThis/Origami/releases/latest"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center rounded-full border border-cyan-300/50 bg-cyan-50/80 px-3 py-1.5 text-xs font-medium text-cyan-800 transition hover:border-cyan-400/60 hover:bg-cyan-100/80 dark:border-cyan-500/30 dark:bg-cyan-950/50 dark:text-cyan-300 dark:hover:border-cyan-400/40 dark:hover:bg-cyan-950/70 sm:px-4 sm:py-2 sm:text-sm"
      >
        {t.header.download}
      </a>
      <a
        href="https://github.com/XiaoXianThis/Origami"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 rounded-full border border-sky-200/80 bg-white/50 px-2.5 py-1.5 text-xs font-medium text-slate-700 backdrop-blur-sm transition hover:border-cyan-300/60 hover:bg-white/80 hover:text-cyan-800 dark:border-slate-600/60 dark:bg-slate-800/50 dark:text-slate-300 dark:hover:border-cyan-500/40 dark:hover:bg-slate-800/80 dark:hover:text-cyan-300 sm:gap-2 sm:px-4 sm:py-2 sm:text-sm"
        aria-label={t.header.githubAria}
      >
        <span class="hidden sm:inline">GitHub</span>
        <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
        </svg>
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    padding: 0;
    transition: padding 0.3s ease;
  }

  .site-header-bar {
    transition:
      background-color 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease,
      backdrop-filter 0.3s ease,
      border-radius 0.3s ease;
  }

  .site-header.is-scrolled {
    padding: 0.75rem 1rem 0;
  }

  .site-header.is-scrolled .site-header-bar {
    border: 1px solid var(--site-header-border);
    border-radius: 1rem;
    background: var(--site-header-bg);
    box-shadow:
      0 4px 24px rgb(14 116 144 / 0.08),
      0 1px 3px rgb(15 23 42 / 0.06);
    backdrop-filter: blur(20px);
  }

  :global(.dark) .site-header.is-scrolled .site-header-bar {
    box-shadow:
      0 4px 24px rgb(0 0 0 / 0.25),
      0 1px 3px rgb(0 0 0 / 0.2);
  }

  @media (min-width: 768px) {
    .site-header.is-scrolled {
      padding: 1rem 1.5rem 0;
    }

    .site-header.is-scrolled .site-header-bar {
      border-radius: 1.25rem;
    }
  }
</style>

<script>
  const header = document.getElementById('site-header');
  const threshold = 12;

  function updateHeader() {
    header?.classList.toggle('is-scrolled', window.scrollY > threshold);
  }

  updateHeader();
  window.addEventListener('scroll', updateHeader, { passive: true });
</script>
