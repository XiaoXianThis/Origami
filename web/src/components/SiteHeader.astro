---
const navItems = [
  { href: '#features', label: '功能' },
  { href: '#hide-modes', label: '隐藏方式' },
  { href: '#demo', label: '演示' },
  { href: '#download', label: '下载' },
  { href: '#getting-started', label: '开始使用' },
];
---

<header id="site-header" class="site-header fixed inset-x-0 top-0 z-50">
  <div class="site-header-bar mx-auto flex max-w-6xl min-w-0 items-center justify-between gap-2 px-4 py-4 sm:gap-3 sm:px-6">
    <a href="#" class="group flex min-w-0 shrink items-center gap-2 sm:gap-3">
      <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-to-br from-cyan-400 to-blue-600 text-sm font-bold text-white shadow-lg shadow-cyan-500/25">
        O
      </span>
      <span class="truncate text-lg font-semibold tracking-tight text-slate-900 transition-colors group-hover:text-cyan-700">
        Origami
      </span>
    </a>

    <nav class="hidden items-center gap-8 md:flex">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'text-sm text-slate-600 transition-colors hover:text-cyan-700',
            item.href === '#demo' && 'demo-hide-narrow-portrait',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex shrink-0 items-center gap-2 sm:gap-3">
      <a
        href="https://github.com/XiaoXianThis/Origami/releases/latest"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center rounded-full border border-cyan-300/50 bg-cyan-50/80 px-3 py-1.5 text-xs font-medium text-cyan-800 transition hover:border-cyan-400/60 hover:bg-cyan-100/80 sm:px-4 sm:py-2 sm:text-sm"
      >
        下载
      </a>
      <a
        href="https://github.com/XiaoXianThis/Origami"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 rounded-full border border-sky-200/80 bg-white/50 px-2.5 py-1.5 text-xs font-medium text-slate-700 backdrop-blur-sm transition hover:border-cyan-300/60 hover:bg-white/80 hover:text-cyan-800 sm:gap-2 sm:px-4 sm:py-2 sm:text-sm"
        aria-label="GitHub 仓库"
      >
        <span class="hidden sm:inline">GitHub</span>
        <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
        </svg>
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    padding: 0;
    transition: padding 0.3s ease;
  }

  .site-header-bar {
    transition:
      background-color 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease,
      backdrop-filter 0.3s ease,
      border-radius 0.3s ease;
  }

  .site-header.is-scrolled {
    padding: 0.75rem 1rem 0;
  }

  .site-header.is-scrolled .site-header-bar {
    border: 1px solid rgb(255 255 255 / 0.75);
    border-radius: 1rem;
    background: rgb(255 255 255 / 0.72);
    box-shadow:
      0 4px 24px rgb(14 116 144 / 0.08),
      0 1px 3px rgb(15 23 42 / 0.06);
    backdrop-filter: blur(20px);
  }

  @media (min-width: 768px) {
    .site-header.is-scrolled {
      padding: 1rem 1.5rem 0;
    }

    .site-header.is-scrolled .site-header-bar {
      border-radius: 1.25rem;
    }
  }
</style>

<script>
  const header = document.getElementById('site-header');
  const threshold = 12;

  function updateHeader() {
    header?.classList.toggle('is-scrolled', window.scrollY > threshold);
  }

  updateHeader();
  window.addEventListener('scroll', updateHeader, { passive: true });
</script>
