---
import ScrollBackground from '../components/ScrollBackground.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Origami — macOS 窗口分组与无痕切换',
  description = 'Origami 把多个 macOS 窗口像浏览器标签页一样折叠成组，叠加标签栏，实现快速、无痕的窗口切换。',
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#E0F2F7" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="generator" content={Astro.generator} />
  </head>
  <body class="relative min-h-screen overflow-x-hidden bg-gradient-to-b from-[#FAF9F6] via-[#E8F4FC] to-[#D6EBF7] text-slate-800 antialiased selection:bg-cyan-400/30 selection:text-slate-900">
    <div
      class="pointer-events-none fixed inset-0 z-0 bg-[url('/theme-bg.png')] bg-cover bg-center opacity-[0.18] mix-blend-soft-light"
      aria-hidden="true"
    ></div>
    <ScrollBackground />
    <div
      class="pointer-events-none fixed inset-0 z-[2] bg-gradient-to-b from-[#FAF9F6]/80 via-transparent to-[#D6EBF7]/90"
      aria-hidden="true"
    ></div>
    <div class="relative z-10">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  html {
    scroll-behavior: smooth;
  }
</style>
