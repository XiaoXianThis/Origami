---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Origami — macOS 窗口分组与无痕切换',
  description = 'Origami 把多个 macOS 窗口像浏览器标签页一样折叠成组，叠加标签栏，实现快速、无痕的窗口切换。',
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0f1117" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="generator" content={Astro.generator} />
  </head>
  <body class="min-h-screen bg-[#0f1117] text-stone-100 antialiased selection:bg-amber-400/30 selection:text-amber-50">
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  html {
    scroll-behavior: smooth;
  }
</style>
